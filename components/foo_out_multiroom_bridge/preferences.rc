#include "preferences_resource.h"

#include <winres.h>
#include <commctrl.h>

LANGUAGE LANG_ENGLISH, SUBLANG_ENGLISH_US
#pragma code_page(1252)

IDD_MULTIROOM_PREFERENCES DIALOGEX 0, 0, 507, 290
STYLE DS_SHELLFONT | DS_CONTROL | WS_CHILD | WS_VISIBLE | WS_CLIPCHILDREN | WS_CLIPSIBLINGS
EXSTYLE WS_EX_CONTROLPARENT
FONT 8, "MS Shell Dlg", 400, 0, 1
{
    CONTROL "", idTabs, "SysTabControl32", TCS_TABS | WS_TABSTOP, 5, 5, 496, 280
}

IDD_MULTIROOM_PAGE_STATUS DIALOGEX 0, 0, 480, 305
STYLE DS_SHELLFONT | DS_CONTROL | WS_CHILD | WS_CLIPCHILDREN | WS_CLIPSIBLINGS
EXSTYLE WS_EX_CONTROLPARENT
FONT 8, "MS Shell Dlg", 400, 0, 1
{
    LTEXT      "Transport", IDC_STATIC, 11, 11, 95, 13
    LTEXT      "AirPlay discovery: not started", idStatusSummary, 109, 11, 250, 13
    PUSHBUTTON "Refresh speakers", idRefreshButton, 11, 35, 110, 14
    LTEXT      "Manual AirPlay", IDC_STATIC, 11, 66, 95, 13
    LTEXT      "Name", IDC_STATIC, 11, 86, 45, 13
    EDITTEXT   idManualName, 61, 84, 122, 14, ES_AUTOHSCROLL
    LTEXT      "Host/IP", IDC_STATIC, 194, 86, 45, 13
    EDITTEXT   idManualHost, 244, 84, 132, 14, ES_AUTOHSCROLL
    LTEXT      "Port", IDC_STATIC, 386, 86, 28, 13
    EDITTEXT   idManualPort, 416, 84, 47, 14, ES_AUTOHSCROLL | ES_NUMBER
    PUSHBUTTON "Add speaker", idManualAddButton, 11, 109, 110, 14
    LTEXT      "Speakers", IDC_STATIC, 11, 139, 95, 13
    CONTROL    "", idSpeakerList, "SysListView32", LVS_REPORT | LVS_SINGLESEL | LVS_SHOWSELALWAYS | WS_BORDER | WS_TABSTOP, 11, 156, 452, 112
}

IDD_MULTIROOM_PAGE_ABOUT DIALOGEX 0, 0, 480, 305
STYLE DS_SHELLFONT | DS_CONTROL | WS_CHILD | WS_CLIPCHILDREN | WS_CLIPSIBLINGS
EXSTYLE WS_EX_CONTROLPARENT
FONT 8, "MS Shell Dlg", 400, 0, 1
{
    LTEXT      "Universal Multiroom Bridge", IDC_STATIC, 11, 9, 250, 13
    LTEXT      "", idAboutVersion, 11, 25, 250, 13
    PUSHBUTTON "Buy me a coffee", idSupportButton, 11, 44, 110, 14
    PUSHBUTTON "GitHub repo", idGitHubButton, 125, 44, 110, 14
}
